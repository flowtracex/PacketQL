{
    "asset_profiler": {
        "enabled": true,
        "sync_interval_seconds": 5,
        "max_profiles_in_memory": 100000
    },
    "log": {
        "path": "./log"
    },
    "write": {
        "flush_buffer_mb": 1,
        "flush_interval_seconds": 60,
        "flush_event_count": 1000
    },
    "kafka_consumer": {
        "topic": "zeek-raw",
        "group_id": "parquet-writer-group-test",
        "max_poll_records": 1000
    },
    "kafka_producer": {
        "topic": "zeek-normalized",
        "compression": "lz4"
    },
    "parquet": {
        "base_path": "./output",
        "file_prefix": "events"
    }
}