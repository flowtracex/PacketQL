# PCAPQL environment example
# Copy to .env and adjust values for your environment.

# App mode
APP_MODE=production

# Frontend API proxy target (Vite dev server)
VITE_API_PROXY_TARGET=http://127.0.0.1:8010

# Backend data paths
NDR_DATA_DIR=/opt/tools/pcapql/data
PARQUET_DATA_DIR=/opt/tools/pcapql/data/parquet

# Kafka (used by enrich pipeline / live stream integrations)
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
